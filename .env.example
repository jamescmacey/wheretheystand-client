# Public read API (v2 paths)
NUXT_PUBLIC_API_BASE=http://localhost:8000/v2/

# Django origin for auth session cookies (no trailing path)
NUXT_PUBLIC_API_ORIGIN=http://localhost:8000

# Nuxt site origin (post-login redirect allowlist; must match browser URL)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Enable /console page and admin composables
NUXT_PUBLIC_ADMIN_ENABLED=false

# Cloudflare Turnstile (contact form); must pair with Django TURNSTILE_SECRET_KEY
TURNSTILE_SITE_KEY=
